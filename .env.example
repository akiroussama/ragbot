# Database
DATABASE_URL=postgresql://chatbot:chatbot123@localhost:5432/chatbot_rag
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot123
POSTGRES_DB=chatbot_rag

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis123

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant123

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_PORT=3000
API_PREFIX=/api/v1

# Admin Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-nextauth-secret-change-this-in-production

# Widget Configuration
WIDGET_ORIGIN=http://localhost:3002

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
DEFAULT_LLM_MODEL=gpt-4-turbo-preview

# Email (for 2FA and notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@chatbot-rag.com

# Stripe (for billing)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Sentry (for error tracking)
SENTRY_DSN=your-sentry-dsn

# Node Environment
NODE_ENV=development
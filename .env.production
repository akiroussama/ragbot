# Production Environment Variables
NODE_ENV=production

# Database (AWS RDS Multi-AZ)
DATABASE_URL=postgresql://chatbot_prod:${PROD_DB_PASSWORD}@chatbot-prod.cluster-xxxxx.us-east-1.rds.amazonaws.com:5432/chatbot_rag_prod
POSTGRES_USER=chatbot_prod
POSTGRES_PASSWORD=${PROD_DB_PASSWORD}
POSTGRES_DB=chatbot_rag_prod

# Redis (AWS ElastiCache Cluster)
REDIS_URL=redis://:${PROD_REDIS_PASSWORD}@chatbot-prod.xxxxx.clustercfg.use1.cache.amazonaws.com:6379
REDIS_PASSWORD=${PROD_REDIS_PASSWORD}

# Qdrant Vector Database (Qdrant Cloud)
QDRANT_URL=https://prod-xxxxx.qdrant.io:6333
QDRANT_API_KEY=${PROD_QDRANT_API_KEY}

# JWT Secrets
JWT_SECRET=${PROD_JWT_SECRET}
JWT_REFRESH_SECRET=${PROD_JWT_REFRESH_SECRET}
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_PORT=3000
API_PREFIX=/api/v1

# Admin Frontend
NEXT_PUBLIC_API_URL=https://api.chatbot-rag.com/api/v1
NEXTAUTH_URL=https://admin.chatbot-rag.com
NEXTAUTH_SECRET=${PROD_NEXTAUTH_SECRET}

# Widget Configuration
WIDGET_ORIGIN=https://widget.chatbot-rag.com

# LLM Configuration
OPENAI_API_KEY=${PROD_OPENAI_API_KEY}
ANTHROPIC_API_KEY=${PROD_ANTHROPIC_API_KEY}
DEFAULT_LLM_MODEL=gpt-4-turbo-preview

# Email (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=${PROD_SENDGRID_API_KEY}
EMAIL_FROM=noreply@chatbot-rag.com

# Stripe (Live keys)
STRIPE_SECRET_KEY=${PROD_STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${PROD_STRIPE_WEBHOOK_SECRET}
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${PROD_STRIPE_PUBLISHABLE_KEY}

# Sentry
SENTRY_DSN=${PROD_SENTRY_DSN}

# Logging
LOG_LEVEL=error

# CORS
CORS_ORIGINS=https://admin.chatbot-rag.com,https://widget.chatbot-rag.com

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=1000

# File Upload (S3)
MAX_FILE_SIZE=10485760
AWS_S3_BUCKET=chatbot-prod-uploads
AWS_REGION=us-east-1
AWS_CLOUDFRONT_URL=https://d1234567890.cloudfront.net

# Web Crawling
CRAWL_MAX_DEPTH=10
CRAWL_MAX_PAGES=1000
CRAWL_TIMEOUT=120000

# Embedding
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=100

# Security
HELMET_CSP=true
SESSION_SECRET=${PROD_SESSION_SECRET}

# Monitoring
DATADOG_API_KEY=${PROD_DATADOG_API_KEY}
NEW_RELIC_LICENSE_KEY=${PROD_NEW_RELIC_LICENSE_KEY}
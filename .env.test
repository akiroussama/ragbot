# Test Environment Variables
NODE_ENV=test

# Database (Test DB)
DATABASE_URL=postgresql://chatbot:chatbot123@localhost:5432/chatbot_rag_test
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot123
POSTGRES_DB=chatbot_rag_test

# Redis (Test Instance)
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=

# Qdrant (Mock)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=test-api-key

# JWT Secrets
JWT_SECRET=test-jwt-secret
JWT_REFRESH_SECRET=test-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_PORT=3000
API_PREFIX=/api/v1

# Admin Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=test-nextauth-secret

# Widget Configuration
WIDGET_ORIGIN=http://localhost:3002

# LLM Configuration (Mocked)
OPENAI_API_KEY=sk-test-key
ANTHROPIC_API_KEY=sk-ant-test-key
DEFAULT_LLM_MODEL=gpt-3.5-turbo

# Email (Mocked)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=test@chatbot-rag.local

# Stripe (Test keys)
STRIPE_SECRET_KEY=sk_test_testing
STRIPE_WEBHOOK_SECRET=whsec_test_testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_testing

# Logging
LOG_LEVEL=error

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Rate Limiting
THROTTLE_TTL=1
THROTTLE_LIMIT=1000

# File Upload
MAX_FILE_SIZE=1048576
UPLOAD_DIR=./test-uploads

# Web Crawling
CRAWL_MAX_DEPTH=1
CRAWL_MAX_PAGES=10
CRAWL_TIMEOUT=5000

# Embedding
CHUNK_SIZE=100
CHUNK_OVERLAP=20
EMBEDDING_BATCH_SIZE=10
# Staging Environment Variables
NODE_ENV=staging

# Database (AWS RDS)
DATABASE_URL=postgresql://chatbot_staging:${STAGING_DB_PASSWORD}@chatbot-staging.cluster-xxxxx.us-east-1.rds.amazonaws.com:5432/chatbot_rag_staging
POSTGRES_USER=chatbot_staging
POSTGRES_PASSWORD=${STAGING_DB_PASSWORD}
POSTGRES_DB=chatbot_rag_staging

# Redis (AWS ElastiCache)
REDIS_URL=redis://:${STAGING_REDIS_PASSWORD}@chatbot-staging.xxxxx.ng.0001.use1.cache.amazonaws.com:6379
REDIS_PASSWORD=${STAGING_REDIS_PASSWORD}

# Qdrant Vector Database (Qdrant Cloud)
QDRANT_URL=https://staging-xxxxx.qdrant.io:6333
QDRANT_API_KEY=${STAGING_QDRANT_API_KEY}

# JWT Secrets
JWT_SECRET=${STAGING_JWT_SECRET}
JWT_REFRESH_SECRET=${STAGING_JWT_REFRESH_SECRET}
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_PORT=3000
API_PREFIX=/api/v1

# Admin Frontend
NEXT_PUBLIC_API_URL=https://api-staging.chatbot-rag.com/api/v1
NEXTAUTH_URL=https://admin-staging.chatbot-rag.com
NEXTAUTH_SECRET=${STAGING_NEXTAUTH_SECRET}

# Widget Configuration
WIDGET_ORIGIN=https://widget-staging.chatbot-rag.com

# LLM Configuration
OPENAI_API_KEY=${STAGING_OPENAI_API_KEY}
ANTHROPIC_API_KEY=${STAGING_ANTHROPIC_API_KEY}
DEFAULT_LLM_MODEL=gpt-4-turbo-preview

# Email (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=${STAGING_SENDGRID_API_KEY}
EMAIL_FROM=noreply@staging.chatbot-rag.com

# Stripe (Test keys)
STRIPE_SECRET_KEY=${STAGING_STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${STAGING_STRIPE_WEBHOOK_SECRET}
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${STAGING_STRIPE_PUBLISHABLE_KEY}

# Sentry
SENTRY_DSN=${STAGING_SENTRY_DSN}

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=https://admin-staging.chatbot-rag.com,https://widget-staging.chatbot-rag.com

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=500

# File Upload (S3)
MAX_FILE_SIZE=10485760
AWS_S3_BUCKET=chatbot-staging-uploads
AWS_REGION=us-east-1

# Web Crawling
CRAWL_MAX_DEPTH=5
CRAWL_MAX_PAGES=500
CRAWL_TIMEOUT=60000

# Embedding
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=100
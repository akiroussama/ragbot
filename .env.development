# Development Environment Variables
NODE_ENV=development

# Database
DATABASE_URL=postgresql://chatbot:chatbot123@localhost:5432/chatbot_rag_dev
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot123
POSTGRES_DB=chatbot_rag_dev

# Redis
REDIS_URL=redis://:redis123@localhost:6379
REDIS_PASSWORD=redis123

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant123

# JWT Secrets
JWT_SECRET=dev-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_PORT=3000
API_PREFIX=/api/v1

# Admin Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production

# Widget Configuration
WIDGET_ORIGIN=http://localhost:3002

# LLM Configuration
OPENAI_API_KEY=sk-dev-test-key
ANTHROPIC_API_KEY=sk-ant-dev-test-key
DEFAULT_LLM_MODEL=gpt-3.5-turbo

# Email (MailHog for dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=dev@chatbot-rag.local

# Stripe (Test keys)
STRIPE_SECRET_KEY=sk_test_development
STRIPE_WEBHOOK_SECRET=whsec_test_development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_development

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Web Crawling
CRAWL_MAX_DEPTH=3
CRAWL_MAX_PAGES=100
CRAWL_TIMEOUT=30000

# Embedding
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=100